# ============================================================
# Azure AD B2C / Microsoft Entra External ID
# ============================================================
# Dominio del tenant B2C (ej: waxvault.b2clogin.com)
VITE_B2C_TENANT=<your-tenant>.b2clogin.com

# Nombre del tenant en formato .onmicrosoft.com
VITE_B2C_TENANT_ID=<your-tenant>.onmicrosoft.com

# Client ID del App Registration del FRONTEND en Azure AD B2C
VITE_B2C_CLIENT_ID=<frontend-app-registration-client-id>

# Nombre del User Flow de Sign Up / Sign In
VITE_B2C_POLICY=B2C_1_signupsignin

# Nombre del scope expuesto por el App Registration del BACKEND
# (ej: waxvault-api → el scope completo sería: https://<tenant-id>/waxvault-api/access_as_user)
VITE_B2C_API_SCOPE=waxvault-api

# ============================================================
# API Backend
# ============================================================
# En desarrollo local, Vite proxy redirige /api → http://localhost:7071
# En producción, apunta al dominio de la Azure Function
VITE_API_BASE_URL=http://localhost:7071/api

# ============================================================
# Auth Redirect
# ============================================================
# URL de redirección después del login (debe estar registrada en B2C)
VITE_REDIRECT_URI=http://localhost:5173
